{
    "languageserver": {
        "lean": {
            "command": "lean-language-server.cmd",
            "args": ["--stdio"],
            "filetypes": ["lean"],
            "trace.server": "verbose",
            "initializationOptions": {
            },
            "settings": {
                "validate": true
            }
        },
        "python": {
            "command": "jedi-language-server",
            "filetypes": ["python"]
        }
    }
}
