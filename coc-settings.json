{
    "coc.preferences.jumpCommand": "tabe",
    "rust-analyzer.updates.channel": "stable",
    "rust-analyzer.checkOnSave.allTargets": false,
    "clangd.enabled": true,
    "inlayHint.enable": false,
    "languageserver": {
        "python": {
            "command": "pylsp",
            "filetypes": [
                "python"
            ]
        },
        "ocaml-lsp": {
            "command": "opam",
            "args": [
                "exec",
                "--",
                "ocamllsp"
            ],
            "filetypes": [
                "ocaml",
                "reason"
            ]
        }
    }
}
