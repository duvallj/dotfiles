{
    "languageserver": {
        "haskell": {
            "command": "haskell-language-server-wrapper",
            "args": ["--lsp"],
            "rootPatterns": [
                "*.cabal",
                "stack.yaml",
                "cabal.project",
                "package.yaml",
                "hie.yaml"
            ],
            "filetypes": ["haskell", "lhaskell"]
        },
        "lean": {
            "command": "lean-language-server.cmd",
            "args": ["--stdio"],
            "filetypes": ["lean"],
            "trace.server": "verbose",
            "initializationOptions": {
            },
            "settings": {
                "validate": true
            }
        },
        "python": {
            "command": "jedi-language-server",
            "filetypes": ["python"]
        },
        "rust": {
            "command": "rust-analyzer-x86_64-pc-windows-msvc",
            "filetypes": ["rust"],
            "rootPatterns": ["Cargo.toml"]
        }
    }
}
