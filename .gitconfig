[core]
	editor = nvim
	autocrlf = false
	eol = lf
	safecrlf = true
	fsmonitor = true
[pull]
	rebase = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[i18n]
	filesEncoding = utf-8
[user]
	name = Jack Duvall
	email = 10897431+duvallj@users.noreply.github.com
[fetch]
	prune = false
[rebase]
	autoStash = true
	autoSquash = true
	forkPoint = false
[merge]
	ff = true
	conflictStyle = diff3
[credential]
	helper = store
[init]
	defaultBranch = main
[scalar]
	repo = /Users/jackduvall/wonder/src
[maintenance]
	repo = /Users/jackduvall/wonder/src
[push]
	autoSetupRemote = true
